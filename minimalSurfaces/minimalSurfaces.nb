Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"enneper3", "[", 
      RowBox[{"r_", ",", "\[Theta]_"}], "]"}], ":=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"r", " ", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "-", 
        RowBox[{
         FractionBox["1", "7"], " ", 
         SuperscriptBox["r", "7"], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"7", " ", "\[Theta]"}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "r"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "-", 
        RowBox[{
         FractionBox["1", "7"], " ", 
         SuperscriptBox["r", "7"], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"7", " ", "\[Theta]"}], "]"}]}]}], ",", 
       RowBox[{
        FractionBox["1", "2"], " ", 
        SuperscriptBox["r", "4"], " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"4", " ", "\[Theta]"}], "]"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{"enneper3", "[", 
      RowBox[{"r", ",", "\[Theta]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", "0", ",", 
       RowBox[{"2", "Pi"}]}], "}"}], ",", 
     RowBox[{"Mesh", "\[Rule]", "Automatic"}], ",", 
     RowBox[{"MeshStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{
        RowBox[{"GrayLevel", "[", "0", "]"}], ",", 
        RowBox[{"Opacity", "[", "1", "]"}], ",", 
        RowBox[{"AbsoluteThickness", "[", "0.7`", "]"}]}], "]"}]}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{
        RowBox[{"RGBColor", "[", 
         RowBox[{".4", ",", ".2", ",", "0.4", ",", ".8"}], "]"}], ",", 
        RowBox[{"Specularity", "[", 
         RowBox[{"White", ",", "10"}], "]"}]}], "]"}]}], ",", 
     RowBox[{"Boxed", "\[Rule]", "False"}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "Full"}]}], "]"}]}]}]], "Input",

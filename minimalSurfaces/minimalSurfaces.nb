Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"enneper2", "[", 
    RowBox[{"r_", ",", "\[Theta]_"}], "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"r", " ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "-", 
      RowBox[{
       FractionBox["1", "5"], " ", 
       SuperscriptBox["r", "5"], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"5", " ", "\[Theta]"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "r"}], " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "-", 
      RowBox[{
       FractionBox["1", "5"], " ", 
       SuperscriptBox["r", "5"], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"5", " ", "\[Theta]"}], "]"}]}]}], ",", 
     RowBox[{
      FractionBox["2", "3"], " ", 
      SuperscriptBox["r", "3"], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"3", " ", "\[Theta]"}], "]"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot3D", "[", 
  RowBox[{
   RowBox[{"enneper2", "[", 
    RowBox[{"r", ",", "\[Theta]"}], "]"}], ",", 
   RowBox[{"{", 

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "w_", "]"}], ":=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "[", "w_", "]"}], ":=", "w"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"para", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Integral]", 
       RowBox[{
        RowBox[{"f", "[", "w", "]"}], 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"g", "[", "w", "]"}], "^", "2"}]}], ")"}], 
        RowBox[{"\[DifferentialD]", "w"}]}]}], ",", 
      RowBox[{"I", 
       RowBox[{"\[Integral]", 
        RowBox[{
         RowBox[{"f", "[", "w", "]"}], " ", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           SuperscriptBox[
            RowBox[{"g", "[", "w", "]"}], "2"]}], ")"}], 
         RowBox[{"\[DifferentialD]", "w"}]}]}]}], ",", 
      RowBox[{"2", 
       RowBox[{"\[Integral]", 
        RowBox[{
         RowBox[{"f", "[", "w", "]"}], " ", 
         RowBox[{"g", "[", "w", "]"}], 
         RowBox[{"\[DifferentialD]", "w"}]}]}]}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"ComplexExpand", "[", 
    RowBox[{"Re", "[", 
     RowBox[{"para", "/.", 
      RowBox[{"w", "->", 
       RowBox[{"x", "+", 
        RowBox[{"I", " ", "y"}]}]}]}], "]"}], "]"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"ComplexExpand", "[", 
  RowBox[{"Re", "[", 
   RowBox[{"para", "/.", 
    RowBox[{"w", "->", 
     RowBox[{"r", " ", 

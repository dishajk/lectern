     RowBox[{"Mesh", "\[Rule]", "Automatic"}], ",", 
     RowBox[{"MeshStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{
        RowBox[{"GrayLevel", "[", "0", "]"}], ",", 

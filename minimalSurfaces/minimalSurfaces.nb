Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"cathel", "[", 
    RowBox[{"u_", ",", "v_", ",", "t_"}], "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Sin", "[", "t", "]"}], "*", " ", 
       RowBox[{"Cosh", "[", "v", "]"}], "*", 
       RowBox[{"Cos", "[", "u", "]"}]}], "+", 
      RowBox[{
       RowBox[{"Cos", "[", "t", "]"}], "*", 
       RowBox[{"Sinh", "[", "v", "]"}], "*", 
       RowBox[{"Sin", "[", "u", "]"}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"Sin", "[", "t", "]"}], "*", 
       RowBox[{"Cosh", "[", "v", "]"}], "*", 
       RowBox[{"Sin", "[", "u", "]"}]}], "-", 
      RowBox[{
       RowBox[{"Cos", "[", "t", "]"}], "*", 
       RowBox[{"Sinh", "[", "v", "]"}], "*", 
       RowBox[{"Cos", "[", "u", "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"v", "*", 
       RowBox[{"Sin", "[", "t", "]"}]}], "+", 
      RowBox[{"u", "*", 
       RowBox[{"Cos", "[", "t", "]"}]}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"ParametricPlot3D", "[", 
